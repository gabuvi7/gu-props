generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum TenantRole {
  OWNER
  ADMIN
  OPERATOR
  READONLY
}

enum PropertyType {
  APARTMENT
  HOUSE
  COMMERCIAL
  LAND
  OTHER
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  INACTIVE
}

enum RentalContractStatus {
  DRAFT
  ACTIVE
  FINISHED
  CANCELLED
}

enum EconomicIndexType {
  IPC
  ICL
  UVA
  FIXED
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERPAID
  VOIDED
}

enum CashMovementType {
  INCOME
  EXPENSE
  ADJUSTMENT
  COMMISSION
  OWNER_PAYOUT
}

enum LiquidationStatus {
  DRAFT
  ISSUED
  PAID
  VOIDED
}

enum DocumentType {
  CONTRACT
  PAYMENT_RECEIPT
  LIQUIDATION
  OTHER
}

enum Currency {
  ARS
  USD
}

model Tenant {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  status        TenantStatus         @default(ACTIVE)
  customDomain  String?              @unique
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  users         TenantUser[]
  settings      TenantSettings?
  features      TenantFeature[]
  subscriptions TenantSubscription[]
  owners        Owner[]
  renters       Renter[]
  properties    Property[]
  contracts     RentalContract[]
  indexValues   CustomIndexValue[]
  payments      Payment[]
  cashMovements CashMovement[]
  liquidations  Liquidation[]
  documents     Document[]
  auditLogs     AuditLog[]

  @@map("tenants")
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  name           String?
  passwordHash   String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenants        TenantUser[]
  auditLogs      AuditLog[]
  uploadedValues CustomIndexValue[]

  @@map("users")
}

model TenantUser {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole
  isActive  Boolean    @default(true)
  invitedAt DateTime   @default(now())
  acceptedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_users")
}

model TenantSettings {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  commercialName        String
  logoUrl               String?
  primaryColor          String?
  defaultCurrency       Currency @default(ARS)
  defaultCommissionBps  Int      @default(0)
  operationalParameters Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId])
  @@map("tenant_settings")
}

model TenantFeature {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  enabled   Boolean  @default(false)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("tenant_features")
}

model TenantSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  plan      String
  status    String
  limits    Json?
  startsAt  DateTime @default(now())
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("tenant_subscriptions")
}

model Owner {
  id             String    @id @default(cuid())
  tenantId       String
  displayName    String
  email          String?
  phone          String?
  taxId          String?
  paymentDetails Json?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  properties     Property[]
  contracts      RentalContract[]
  liquidations   Liquidation[]

  @@unique([id, tenantId])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, displayName])
  @@map("owners")
}

model Renter {
  id              String    @id @default(cuid())
  tenantId        String
  displayName     String
  email           String?
  phone           String?
  identityNumber  String?
  guaranteeInfo   Json?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contracts       RentalContract[]
  payments        Payment[]

  @@unique([id, tenantId])
  @@unique([tenantId, identityNumber])
  @@index([tenantId])
  @@index([tenantId, displayName])
  @@map("renters")
}

model Property {
  id              String         @id @default(cuid())
  tenantId        String
  ownerId         String
  type            PropertyType
  status          PropertyStatus @default(AVAILABLE)
  addressLine     String
  city            String?
  province        String?
  postalCode      String?
  commissionBps   Int?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner           Owner          @relation(fields: [ownerId, tenantId], references: [id, tenantId])
  contracts       RentalContract[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, status])
  @@map("properties")
}

model RentalContract {
  id                    String               @id @default(cuid())
  tenantId              String
  propertyId            String
  ownerId               String
  renterId              String
  status                RentalContractStatus @default(DRAFT)
  startsAt              DateTime
  endsAt                DateTime
  rentAmount            Decimal              @db.Decimal(14, 2)
  currency              Currency             @default(ARS)
  dueDayOfMonth         Int
  adjustmentIndexType   EconomicIndexType
  adjustmentPeriodMonths Int
  nextAdjustmentAt      DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property              Property             @relation(fields: [propertyId, tenantId], references: [id, tenantId])
  owner                 Owner                @relation(fields: [ownerId, tenantId], references: [id, tenantId])
  renter                Renter               @relation(fields: [renterId, tenantId], references: [id, tenantId])
  payments              Payment[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@index([tenantId, ownerId])
  @@index([tenantId, renterId])
  @@index([tenantId, status])
  @@map("rental_contracts")
}

model EconomicIndex {
  id        String            @id @default(cuid())
  type      EconomicIndexType
  name      String
  source    String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  values    CustomIndexValue[]

  @@unique([type, name])
  @@map("economic_indices")
}

model CustomIndexValue {
  id              String        @id @default(cuid())
  tenantId        String
  economicIndexId String
  periodDate      DateTime
  value           Decimal       @db.Decimal(18, 6)
  isManual        Boolean       @default(true)
  uploadedById    String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  economicIndex   EconomicIndex @relation(fields: [economicIndexId], references: [id])
  uploadedBy      User?         @relation(fields: [uploadedById], references: [id])

  @@unique([id, tenantId])
  @@unique([tenantId, economicIndexId, periodDate])
  @@index([tenantId])
  @@index([economicIndexId])
  @@map("custom_index_values")
}

model Payment {
  id              String        @id @default(cuid())
  tenantId        String
  contractId      String
  renterId        String
  status          PaymentStatus @default(PENDING)
  dueAmount       Decimal       @db.Decimal(14, 2)
  paidAmount      Decimal       @db.Decimal(14, 2)
  remainingDebt   Decimal       @db.Decimal(14, 2)
  creditBalance   Decimal       @db.Decimal(14, 2)
  currency        Currency      @default(ARS)
  paidAt          DateTime?
  dueAt           DateTime
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract        RentalContract @relation(fields: [contractId, tenantId], references: [id, tenantId])
  renter          Renter        @relation(fields: [renterId, tenantId], references: [id, tenantId])
  cashMovements   CashMovement[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, contractId])
  @@index([tenantId, renterId])
  @@index([tenantId, status])
  @@map("payments")
}

model CashMovement {
  id          String           @id @default(cuid())
  tenantId    String
  paymentId   String?
  type        CashMovementType
  amount      Decimal          @db.Decimal(14, 2)
  currency    Currency         @default(ARS)
  occurredAt  DateTime         @default(now())
  sourceType  String?
  sourceId    String?
  reason      String?
  createdById String?
  createdAt   DateTime         @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment     Payment?         @relation(fields: [paymentId, tenantId], references: [id, tenantId])

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, occurredAt])
  @@index([tenantId, paymentId])
  @@map("cash_movements")
}

model Liquidation {
  id             String            @id @default(cuid())
  tenantId       String
  ownerId        String
  status         LiquidationStatus @default(DRAFT)
  periodStart    DateTime
  periodEnd      DateTime
  grossAmount    Decimal           @db.Decimal(14, 2)
  commissionAmount Decimal         @db.Decimal(14, 2)
  netAmount      Decimal           @db.Decimal(14, 2)
  currency       Currency          @default(ARS)
  issuedAt       DateTime?
  paidAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner          Owner             @relation(fields: [ownerId, tenantId], references: [id, tenantId])

  @@unique([id, tenantId])
  @@unique([tenantId, ownerId, periodStart, periodEnd])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("liquidations")
}

model Document {
  id          String       @id @default(cuid())
  tenantId    String
  type        DocumentType
  fileName    String
  mimeType    String
  storageKey  String
  entityType  String?
  entityId    String?
  createdById String?
  createdAt   DateTime     @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([tenantId, storageKey])
  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@map("documents")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  requestId   String?
  entityType  String
  entityId    String?
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
